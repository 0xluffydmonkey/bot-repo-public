# ============================================================
# .env.example — copy to .env and fill in NON-SECRET values only
#
# SECRETS MUST NOT be stored in .env (or anywhere inside the project).
# Keys marked [SECRET] below must be injected via one of:
#
#   Option A — systemd (recommended for production):
#     In your .service unit file:
#       Environment="TELEGRAM_API_ID=12345678"
#       Environment="TELEGRAM_API_HASH=abcdef..."
#     Or point to a file outside the project:
#       EnvironmentFile=/opt/bot/secrets/bot-secrets.env
#
#   Option B — external secrets file (dev/staging):
#     Create /opt/bot/secrets/bot-secrets.env (chmod 600, owned by bot user)
#     chmod 600 /opt/bot/secrets/bot-secrets.env
#     Set in your environment (or .env):
#       BOT_SECRETS_FILE=/opt/bot/secrets/bot-secrets.env
#
# Format for /opt/bot/secrets/bot-secrets.env:
#   SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
#   TELEGRAM_API_ID=12345678
#   TELEGRAM_API_HASH=your_hash_here
#   TELEGRAM_PHONE=+5511999999999
#   TELEGRAM_BOT_TOKEN=1234567890:AABBccDDeeffGGhhIIjj...
#   TELEGRAM_CONTROL_ALLOWED_IDS=123456789,987654321
# ============================================================

# ============================================================
# SOLANA
# ============================================================
# [SECRET] RPC endpoint with API key — inject externally, do NOT set here
SOLANA_RPC_URL=SET_IN_SERVER_ONLY
SOLANA_CLUSTER=mainnet-beta

# ============================================================
# SECRETS — paths to files OUTSIDE the repository
# ============================================================
# Wallet keypair — generate with: solana-keygen new -o /opt/bot/secrets/drift-bot-wallet.json
# Accepted formats: JSON byte array (Solana CLI) or base58 string
BOT_WALLET_PATH=/opt/bot/secrets/drift-bot-wallet.json

# Informational only — not used by the bot directly
BOT_PUBLIC_KEY=

# Path to external secrets env file (optional — the path itself is not a secret)
# BOT_SECRETS_FILE=/opt/bot/secrets/bot-secrets.env

# ============================================================
# TELEGRAM (MTProto User Client)
# Obtain credentials at: https://my.telegram.org/apps
# [SECRET] — inject externally, do NOT set here
# ============================================================
TELEGRAM_API_ID=SET_IN_SERVER_ONLY
TELEGRAM_API_HASH=SET_IN_SERVER_ONLY
TELEGRAM_PHONE=SET_IN_SERVER_ONLY   # Ex: +5511999999999

# Path to session file (generated on first interactive boot)
# After first login: mv telegram_session.txt /opt/bot/secrets/telegram_session.txt
TELEGRAM_SESSION_PATH=/opt/bot/secrets/telegram_session.txt

# ID or @username of the channel to monitor
# Discover the ID: forward a message to @userinfobot
TELEGRAM_CHANNEL_ID=   # Ex: -1001234567890 or @canaldesinais

# ============================================================
# TRADING
# ============================================================
# Paper trading mode (true = simulation, false = real money)
PAPER_TRADING=true

# Position size as % of account equity per trade (e.g. 0.05 = 5%)
POSITION_SIZE_PCT=0.05

# Maximum slippage tolerance in bps (100 = 1%)
MAX_SLIPPAGE_BPS=100

# Maximum leverage allowed by the bot (safety cap)
MAX_LEVERAGE=20

# Delay before executing a signal in ms (0 = immediate)
EXECUTION_DELAY_MS=0

# Number of retries on failure
MAX_RETRIES=3

# Maximum simultaneous open positions
MAX_POSITIONS=5

# Minimum free collateral to keep as a safety buffer (e.g. 0.10 = 10%)
MIN_FREE_MARGIN_PCT=0.10

# Maximum total notional exposure as % of equity (e.g. 0.80 = 80%)
MAX_TOTAL_EXPOSURE_PCT=0.80

# PnL card refresh interval in ms
PNL_REFRESH_INTERVAL_MS=30000

# ============================================================
# FEATURE TOGGLES — controls which modules start
#
# The canonical start command is: ./start.sh
# These toggles (not CLI flags) decide what runs.
#
# ENABLE_SIGNAL_LISTENER  — Telegram MTProto listener for trade signals
# ENABLE_WEB              — Express + Socket.IO web dashboard
# ENABLE_CONTROL_BOT      — Telegram control bot with InlineKeyboard
#
# Common combinations:
#   Trading only:          LISTENER=true  WEB=false  CONTROL=false
#   Trading + dashboard:   LISTENER=true  WEB=true   CONTROL=false
#   Full stack:            LISTENER=true  WEB=true   CONTROL=true
#   Dashboard only:        LISTENER=false WEB=true   CONTROL=false
# ============================================================
ENABLE_SIGNAL_LISTENER=true
ENABLE_WEB=false
WEB_PORT=3000

ENABLE_CONTROL_BOT=false

# [SECRET] Token from @BotFather — inject externally, do NOT set here
TELEGRAM_BOT_TOKEN=SET_IN_SERVER_ONLY

# [SECRET] Comma-separated user IDs allowed to use the control bot
# Discover your ID: send any message to @userinfobot
TELEGRAM_CONTROL_ALLOWED_IDS=SET_IN_SERVER_ONLY

# ============================================================
# LOGS
# ============================================================
LOG_LEVEL=info   # debug | info | warn | error
LOG_DIR=./logs
