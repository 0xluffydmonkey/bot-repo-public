# ============================================================
# .env.example — copy to backend/.env and fill in NON-SECRET values only
#
# SECRETS MUST NOT be stored in .env (or anywhere inside the project).
# Keys marked [SECRET] below must be injected via one of:
#
#   Option A — systemd (recommended for production):
#     In your .service unit file:
#       EnvironmentFile=/opt/bot/secrets/bot-secrets.env
#     Or inline per-secret:
#       Environment="TELEGRAM_API_ID=12345678"
#
#   Option B — external secrets file (dev/staging):
#     Create /opt/bot/secrets/bot-secrets.env (chmod 600, owned by bot user)
#     Set BOT_SECRETS_FILE in systemd or before launching:
#       BOT_SECRETS_FILE=/opt/bot/secrets/bot-secrets.env
#
# Format for /opt/bot/secrets/bot-secrets.env:
#   SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
#   TELEGRAM_API_ID=12345678
#   TELEGRAM_API_HASH=your_hash_here
#   TELEGRAM_PHONE=+5511999999999
#   TELEGRAM_BOT_TOKEN=1234567890:AABBccDDeeffGGhhIIjj...
#   TELEGRAM_CHAT_ID=123456789
#   TELEGRAM_CONTROL_ALLOWED_IDS=123456789,987654321
#   WEB_API_TOKEN=long-random-token-for-remote-dashboard-actions
#   JUPITER_API_KEY=your_jupiter_key_if_required
#   PHOENIX_API_KEY=your_phoenix_key_if_required
#   PHOENIX_ACCESS_CODE=your_phoenix_access_code
#
# Multi-venue wallet paths (optional — see WALLET & KEYS section below):
#   WALLET_DRIFT_PATH=/opt/bot/wallets/drift.json
#   WALLET_JUPITER_PATH=/opt/bot/wallets/jupiter.json
#   WALLET_PHOENIX_PATH=/opt/bot/wallets/phoenix.json
#
# Non-wallet key paths for venues that use a signing agent:
#   VALIANT_AGENT_KEY_PATH=/opt/bot/secrets/valiant-agent-key.txt
#   VALIANT_MAIN_KEY_PATH=/opt/bot/secrets/valiant-main-key.txt
#   VALIANT_ACCOUNT_ADDRESS=0xYourPublicAccountAddress
#
# IMPORTANT — two distinct keys for Hyperliquid:
#   VALIANT_AGENT_KEY_PATH  — the API/agent wallet key used for signing ORDERS.
#                             This wallet must be registered as an API wallet on
#                             the Hyperliquid UI under your main account.
#   VALIANT_MAIN_KEY_PATH   — the MAIN ACCOUNT private key, used to sign
#                             transfers (usdClassTransfer).  Hyperliquid does NOT
#                             allow agent wallets to sign transfers — only the
#                             main account can. If this is not set, the bot falls
#                             back to the agent key (only correct when both keys
#                             are the same address).
#   Example:
#     VALIANT_MAIN_KEY_PATH=/opt/bot/secrets/valiant-main-key.txt
# ============================================================

# ============================================================
# SOLANA
# ============================================================
# [SECRET for Solana-based venues] RPC endpoint with API key.
# Required only when the selected venue/backend needs Solana RPC.
# Inject externally, do NOT set real values here.
SOLANA_RPC_URL=SET_IN_SERVER_ONLY

# Solana cluster name (informational; bot uses RPC URL directly)
SOLANA_CLUSTER=mainnet-beta

# ============================================================
# WALLET & KEYS
# ============================================================
# Global fallback wallet path — used when no venue-specific wallet is configured.
# This is the path to the keypair FILE (not the key itself). The file must live
# OUTSIDE the repository. Accepted formats: JSON byte array (Solana CLI) or base58.
# Example: /opt/bot/secrets/bot-wallet.json
BOT_WALLET_PATH=/opt/bot/secrets/bot-wallet.json

# Informational only — not used by the bot at runtime
BOT_PUBLIC_KEY=

# ──────────────────────────────────────────────────────────────
# MULTI-VENUE WALLETS (optional — set in BOT_SECRETS_FILE only)
# ──────────────────────────────────────────────────────────────
# The bot supports a separate wallet/key path for each venue/backend.
# Configure these in /opt/bot/secrets/bot-secrets.env — never here.
#
# WALLET_DRIFT_PATH   — wallet used for Drift trades
#                        If not set, falls back to BOT_WALLET_PATH (backward compatible)
# WALLET_JUPITER_PATH — wallet used for Jupiter Perps trades
#                        Required when PERP_OPEN_VENUE=jupiter; bot will not start without it
# WALLET_PHOENIX_PATH — wallet used for Phoenix Perps trades
#                        Required when PERP_OPEN_VENUE=phoenix; bot will not start without it
#
# Example (add to /opt/bot/secrets/bot-secrets.env):
#   WALLET_DRIFT_PATH=/opt/bot/wallets/drift.json
#   WALLET_JUPITER_PATH=/opt/bot/wallets/jupiter.json
#   WALLET_PHOENIX_PATH=/opt/bot/wallets/phoenix.json
#
# Each wallet file must be chmod 600, owned by the bot user.
#
# Some non-Solana venues use a signing-agent key instead of a Solana wallet.
# Store the raw key in a dedicated chmod 600 file and expose only the path:
#   VALIANT_AGENT_KEY_PATH=/opt/bot/secrets/valiant-agent-key.txt   # orders
#   VALIANT_MAIN_KEY_PATH=/opt/bot/secrets/valiant-main-key.txt     # transfers
#   VALIANT_ACCOUNT_ADDRESS=0xYourPublicAccountAddress

# ============================================================
# CONFIG FILE PATHS
# ============================================================
# Path to external secrets env file (the path itself is not a secret)
# Uncomment and set this to load secrets from a file instead of systemd
# BOT_SECRETS_FILE=/opt/bot/secrets/bot-secrets.env

# Override the .env path used by the bot (optional — defaults to backend/.env)
# BOT_ENV_FILE=

# ============================================================
# TELEGRAM — MTProto User Client (signal listener)
# Obtain credentials at: https://my.telegram.org/apps
# [SECRET] — inject externally, do NOT set here
# ============================================================
TELEGRAM_API_ID=SET_IN_SERVER_ONLY
TELEGRAM_API_HASH=SET_IN_SERVER_ONLY
TELEGRAM_PHONE=SET_IN_SERVER_ONLY   # Ex: +5511999999999

# Path to the MTProto session file (generated on first interactive boot)
# After first login: mv telegram_session.txt /opt/bot/secrets/telegram_session.txt
TELEGRAM_SESSION_PATH=/opt/bot/secrets/telegram_session.txt

# ID or @username of the Telegram channel to monitor for trade signals
# Discover the numeric ID: forward a channel message to @userinfobot
TELEGRAM_CHANNEL_ID=   # Ex: -1001234567890 or @canaldesinais

# ============================================================
# TELEGRAM — Control Bot & Profit Alerts (optional)
# [SECRET] — these MUST live in the secrets file only, never here.
#
# Add the following to /opt/bot/secrets/bot-secrets.env:
#   TELEGRAM_BOT_TOKEN=<token from @BotFather>
#   TELEGRAM_CHAT_ID=<your personal or group chat ID for profit alerts>
#   TELEGRAM_CONTROL_ALLOWED_IDS=<comma-separated user IDs>
# ============================================================

# ============================================================
# WEB DASHBOARD AUTH (optional, remote access only)
# ============================================================
# [SECRET] — set only in /opt/bot/secrets/bot-secrets.env, never here.
#
# If WEB_API_TOKEN is set, critical dashboard/API actions require:
#   X-API-Token: <WEB_API_TOKEN>
#
# If WEB_API_TOKEN is not set, critical actions are restricted to localhost.
#
# Add to /opt/bot/secrets/bot-secrets.env when accessing remotely:
#   WEB_API_TOKEN=<long-random-token>

# ============================================================
# TRADING
# ============================================================
# Paper trading mode: true = simulation only, false = REAL MONEY
PAPER_TRADING=true

# Position size as a fraction of account equity per trade (e.g. 0.05 = 5%)
POSITION_SIZE_PCT=0.05

# Maximum slippage tolerance in basis points (100 bps = 1%)
MAX_SLIPPAGE_BPS=100

# Hard cap on leverage regardless of signal value
MAX_LEVERAGE=20

# Delay before executing a signal in milliseconds (0 = immediate)
EXECUTION_DELAY_MS=0

# Number of retries on network or execution failure
MAX_RETRIES=3

# Maximum number of simultaneous open positions
MAX_POSITIONS=5

# Minimum free collateral to keep as a safety buffer (0.10 = 10%)
MIN_FREE_MARGIN_PCT=0.10

# Maximum total notional exposure as a fraction of equity (0.80 = 80%)
MAX_TOTAL_EXPOSURE_PCT=0.80

# How often to refresh account data from the chain, in milliseconds
PNL_REFRESH_INTERVAL_MS=30000

# ============================================================
# POSITION MANAGEMENT — Profit Alerts & Trailing Stop
# ============================================================
# Send a Telegram profit alert when a position reaches the threshold below
ENABLE_POSITION_ALERTS=true

# Profit % at which the alert fires (e.g. 10 = alert at +10% PnL)
POSITION_ALERT_PROFIT_PERCENT=10

# Activate a trailing stop loss to protect profits as the position moves
ENABLE_TRAILING_STOP=true

# Distance of the trail below the highest price for LONG (or above lowest for SHORT), in %
# E.g. 5 means the stop trails 5% behind the best price seen
TRAILING_STOP_PERCENT=5

# Trailing stop only activates after this profit % is reached (avoids stopping out too early)
TRAILING_STOP_ONLY_AFTER_PROFIT_PERCENT=3

# ============================================================
# COST ESTIMATION
# ============================================================
# Enable pre-trade cost estimation (fees, funding, price impact) before execution
# The result is logged and surfaced via notes[] but never blocks execution
ENABLE_COST_ESTIMATION=true

# ============================================================
# VENUE SELECTION — Multi-Backend Execution
# ============================================================
# Which perpetuals backend/venue to use for opening and closing trades.
# Registered values in this codebase: drift | jupiter | phoenix | valiant
# Read docs/en/venues.md or docs/pt-BR/venues.md before switching this.
# Live mode fails fast if the selected backend lacks required capabilities.
PERP_OPEN_VENUE=drift

# Extra safety gate for venues/backends that require explicit live auto-trading approval.
# Keep false until you have completed paper testing and backend-specific preflight.
ENABLE_AUTO_TRADING_VALIANT=false

# Optional auto-transfer from Hyperliquid spot wallet to perps margin when perps balance is zero.
# DISABLED by default.  Only enable after reading the following:
#   - Valiant risk/equity assessment can count spot USDC as effective backing equity
#     even when perps freeCollateral is zero. This assessment is NOT dependent on
#     auto-transfer being enabled.
#   - When triggered, the bot transfers the FULL available spot USDC balance to the perps margin account.
#   - This is an L2-internal transfer within Hyperliquid — funds do not leave the exchange.
#   - It is reversible manually via the Hyperliquid UI (Transfer → Perps → Spot).
#   - Only applies to venue=valiant in live mode.  Paper mode and other venues are unaffected.
#   - Trigger condition: perps freeCollateral == 0 at signal execution time.
#   - Fails closed: if the transfer API errors or post-transfer state is still zero, the order is blocked.
ENABLE_VALIANT_AUTO_MARGIN_TRANSFER=false

# Base URL for the Jupiter Perps REST API (non-sensitive)
JUPITER_API_BASE_URL=https://api.jup.ag

# Base URL for the Phoenix Perps REST API (non-sensitive)
PHOENIX_API_BASE_URL=https://api.phoenix.trade

# Base URL for Valiant-compatible Hyperliquid API (non-sensitive)
VALIANT_BASE_URL=https://api.hyperliquid.xyz
VALIANT_CHAIN_ID=1337
VALIANT_HYPERLIQUID_CHAIN=Mainnet
VALIANT_SIGNATURE_CHAIN_ID=0xa4b1

# Valiant/Hyperliquid post-open validation:
#   - Confirm the position exists in the Hyperliquid UI.
#   - Confirm TP and SL are present in the UI.
#   - If TP/SL are missing, treat the position as unprotected; set manually or close it.
#   - Check logs: [HL] TP wire, [HL] SL wire, [VALIANT] TP/SL placement falhou.

# ============================================================
# FEATURE TOGGLES — controls which modules start
#
# The canonical start command is: ./start.sh
# These toggles (not CLI flags) decide what runs.
#
# ENABLE_SIGNAL_LISTENER  — Telegram MTProto listener for trade signals
# ENABLE_WEB              — Express + Socket.IO web dashboard
# ENABLE_CONTROL_BOT      — Telegram control bot with InlineKeyboard
#
# Common combinations:
#   Trading only:          LISTENER=true  WEB=false  CONTROL=false
#   Trading + dashboard:   LISTENER=true  WEB=true   CONTROL=false
#   Full stack:            LISTENER=true  WEB=true   CONTROL=true
#   Dashboard only:        LISTENER=false WEB=true   CONTROL=false
# ============================================================
ENABLE_SIGNAL_LISTENER=true
ENABLE_WEB=false
ENABLE_CONTROL_BOT=false

# TCP port for the web dashboard (only used when ENABLE_WEB=true)
WEB_PORT=3000

# Bind address for the web server — leave empty to bind to all interfaces (0.0.0.0)
WEB_HOST=

# Interval in milliseconds between live backend account data refreshes.
# NOTE: This is the effective polling knob. PNL_REFRESH_INTERVAL_MS (in the TRADING
# section above) populates config.trading.pnlRefreshIntervalMs but the account poller
# reads MONITOR_REFRESH_MS directly — change this one to adjust the actual polling rate.
MONITOR_REFRESH_MS=30000

# ============================================================
# PERSISTENCE — Supabase / PostgreSQL (opcional)
# ============================================================
# Se não configurado, o bot opera normalmente sem persistência.
# A connection string é um segredo — NUNCA defina SUPABASE_DB_URL diretamente.
# Siga o padrão *_PATH: escreva a URL no arquivo e aponte o caminho aqui.
#
# Passo a passo:
#   1. Crie o arquivo fora do repositório (chmod 600):
#        echo "postgresql://postgres.xxx:password@aws-0-...supabase.com:5432/postgres" \
#          > /opt/bot/secrets/supabase-db-url.txt
#        chmod 600 /opt/bot/secrets/supabase-db-url.txt
#   2. Defina o caminho abaixo (apenas o caminho, nunca a URL em si):
#        SUPABASE_DB_URL_PATH=/opt/bot/secrets/supabase-db-url.txt
#   3. Crie a tabela `trades` no Supabase (ver comentário em persistenceService.js)
#
# SUPABASE_DB_URL_PATH=/opt/bot/secrets/supabase-db-url.txt

# ============================================================
# LOGS
# ============================================================
LOG_LEVEL=info   # debug | info | warn | error
LOG_DIR=./logs
