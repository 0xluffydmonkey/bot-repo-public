    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@tanstack/react-query": "^5.76.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
